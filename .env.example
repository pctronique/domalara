NAME_PROJECT=domalara
NAME_HTTPD_CONTAINER=domalara_httpd
NAME_PHP_CONTAINER=domalara_php
NAME_MARIABD_CONTAINER=domalara_mariadb
NAME_PHPMYADMIN_CONTAINER=domalara_phpmyadmin
NAME_MAILHOG_CONTAINER=domalara_mailhog
VALUE_HTTPD_VERSION=latest
VALUE_MARIABD_VERSION=focal
VALUE_PHPMYADMIN_VERSION=latest
VALUE_MAILHOG_VERSION=latest
VALUE_HTTPD_PORT=80
VALUE_PHPMYADMIN_PORT=8080
VALUE_MAILHOG_DISPLAY_PORT=8020
NAME_TYPE_SGBD=mariadb
FOLDER_PHP=.docker/php/
FOLDER_SGBD=.docker/mariadb/
SGBD_DATABASE=domalara
SGBD_ROOT_USERNAME=root
SGBD_ROOT_PASSWORD=secret
